<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>JaveMóvil – Rutas Accesibles</title>
<style>
  :root {
    --jave-blue: #0a2472;
    --jave-blue-mid: #1a3a8f;
    --jave-blue-light: #1e4fcf;
    --jave-yellow: #f5c800;
    --jave-yellow-dark: #d4a800;
    --white: #ffffff;
    --gray-bg: #f4f5f8;
    --gray-text: #6b7280;
    --gray-border: #e2e4ea;
    --green-acc: #2d7d46;
    --green-light: #e8f5ec;
    --orange-acc: #c95e1a;
    --orange-light: #fdf0e8;
    --red-acc: #c0392b;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Segoe UI', system-ui, sans-serif;
    background: #1a1a2e;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    min-height: 100vh;
    padding: 20px;
    gap: 24px;
    flex-wrap: wrap;
  }

  /* ── DEVICE FRAME ── */
  .device {
    width: 375px;
    background: #000;
    border-radius: 44px;
    padding: 10px;
    box-shadow: 0 32px 80px rgba(0,0,0,0.6), inset 0 0 0 1px #333;
    flex-shrink: 0;
  }
  .device-inner {
    width: 100%;
    background: var(--white);
    border-radius: 36px;
    overflow: hidden;
    position: relative;
    height: 760px;
    display: flex;
    flex-direction: column;
  }

  /* ── STATUS BAR ── */
  .status-bar {
    background: var(--jave-blue);
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 20px 6px;
    flex-shrink: 0;
  }
  .status-bar span { color: #fff; font-size: 12px; font-weight: 600; }

  /* ── HEADER ── */
  .app-header {
    background: var(--jave-blue);
    padding: 10px 16px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }
  .app-header .back-btn {
    color: #fff;
    font-size: 22px;
    cursor: pointer;
    background: none;
    border: none;
    line-height: 1;
    padding: 2px 4px;
    opacity: 0.9;
  }
  .app-header h1 {
    color: #fff;
    font-size: 17px;
    font-weight: 700;
    flex: 1;
    text-align: center;
  }
  .app-header .search-btn {
    color: #fff;
    font-size: 20px;
    background: none;
    border: none;
    cursor: pointer;
    opacity: 0.9;
    width: 28px;
    text-align: center;
  }

  /* ── SCREENS ── */
  .screen { display: none; flex-direction: column; flex: 1; overflow: hidden; }
  .screen.active { display: flex; }
  .screen-body { flex: 1; overflow-y: auto; background: var(--gray-bg); }
  .screen-body::-webkit-scrollbar { display: none; }

  /* ══════════════════════════════════
     SCREEN 1 – CATÁLOGO (HOME)
  ══════════════════════════════════ */
  .catalog-header {
    background: var(--jave-blue);
    padding: 0 0 16px;
  }
  .catalog-greeting {
    padding: 6px 16px 14px;
  }
  .catalog-greeting .hello { color: rgba(255,255,255,0.7); font-size: 12px; }
  .catalog-greeting .name { color: #fff; font-size: 16px; font-weight: 700; margin-top: 1px; }

  .acc-banner {
    margin: 0 12px;
    background: var(--jave-yellow);
    border-radius: 12px;
    padding: 12px 14px;
    display: flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    transition: opacity .15s;
  }
  .acc-banner:active { opacity: .85; }
  .acc-banner .ab-icon {
    width: 42px; height: 42px;
    background: var(--jave-blue);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    font-size: 22px;
  }
  .acc-banner .ab-text .ab-label { font-size: 13px; font-weight: 700; color: var(--jave-blue); }
  .acc-banner .ab-text .ab-sub { font-size: 11px; color: var(--jave-blue); opacity: .75; margin-top: 1px; }
  .acc-banner .ab-arrow { margin-left: auto; color: var(--jave-blue); font-size: 18px; font-weight: 700; }

  .catalog-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--gray-border);
    margin-top: 12px;
  }
  .catalog-item {
    background: var(--white);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 16px 6px 12px;
    cursor: pointer;
    transition: background .15s;
    gap: 8px;
  }
  .catalog-item:active { background: var(--gray-bg); }
  .catalog-item.highlight { background: #e8f0ff; }
  .catalog-item .ci-icon {
    width: 44px; height: 44px;
    display: flex; align-items: center; justify-content: center;
    font-size: 26px;
  }
  .catalog-item .ci-label {
    font-size: 10px;
    color: var(--jave-blue);
    font-weight: 600;
    text-align: center;
    line-height: 1.3;
  }
  .catalog-item.highlight .ci-label { color: var(--jave-blue-light); }

  /* floating menu */
  .fab { position: absolute; bottom: 14px; left: 14px; z-index: 50; cursor: pointer; }
  .fab-circle {
    width: 54px; height: 54px;
    border-radius: 50%;
    background: var(--jave-blue);
    display: flex; align-items: center; justify-content: center;
    font-size: 26px;
    box-shadow: 0 4px 16px rgba(10,36,114,0.4);
    transition: transform .2s;
  }
  .fab:active .fab-circle { transform: scale(.93); }

  /* ══════════════════════════════════
     SCREEN 2 – CAMPUS BASE
  ══════════════════════════════════ */
  .campus-map-area {
    position: relative;
    height: 340px;
    background: #e8f0e0;
    overflow: hidden;
    flex-shrink: 0;
  }
  .campus-map-area svg { width: 100%; height: 100%; }

  .map-controls {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .map-ctrl-cross {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 2px;
  }
  .mc-btn {
    width: 36px; height: 36px;
    background: var(--jave-blue);
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    color: #fff;
    font-size: 16px;
    cursor: pointer;
    border: none;
  }
  .mc-btn.empty { background: transparent; cursor: default; }

  .acc-toggle-bar {
    background: var(--white);
    border-bottom: 1px solid var(--gray-border);
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }
  .acc-toggle-bar .att-label { font-size: 13px; font-weight: 700; color: var(--jave-blue); flex: 1; }
  .toggle-switch {
    width: 44px; height: 24px;
    background: var(--jave-blue);
    border-radius: 12px;
    position: relative;
    cursor: pointer;
    transition: background .2s;
    flex-shrink: 0;
  }
  .toggle-switch::after {
    content: '';
    position: absolute;
    right: 3px; top: 3px;
    width: 18px; height: 18px;
    background: #fff;
    border-radius: 50%;
    transition: right .2s;
  }
  .toggle-switch.off { background: #ccc; }
  .toggle-switch.off::after { right: auto; left: 3px; }

  .campus-legend {
    background: var(--white);
    padding: 8px 14px;
    display: flex;
    gap: 16px;
    border-bottom: 1px solid var(--gray-border);
    flex-shrink: 0;
  }
  .leg-item { display: flex; align-items: center; gap: 5px; }
  .leg-dot { width: 11px; height: 11px; border-radius: 50%; flex-shrink: 0; }
  .leg-item span { font-size: 10px; color: var(--gray-text); font-weight: 500; }

  .campus-cta {
    background: var(--white);
    padding: 10px 14px 12px;
    flex-shrink: 0;
  }
  .campus-cta button {
    width: 100%;
    background: var(--jave-blue);
    color: #fff;
    border: none;
    border-radius: 10px;
    padding: 12px;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  /* ══════════════════════════════════
     SCREEN 3 – CONFIGURAR RUTA
  ══════════════════════════════════ */
  .config-section {
    background: var(--white);
    margin-bottom: 8px;
    padding: 14px 14px 12px;
  }
  .cs-title {
    font-size: 11px;
    font-weight: 700;
    color: var(--jave-blue);
    text-transform: uppercase;
    letter-spacing: .6px;
    margin-bottom: 10px;
  }
  .movilidad-btns {
    display: flex;
    gap: 6px;
  }
  .mv-btn {
    flex: 1;
    border: 1.5px solid var(--gray-border);
    border-radius: 8px;
    padding: 8px 4px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    cursor: pointer;
    background: var(--white);
    transition: all .15s;
  }
  .mv-btn .mv-icon { font-size: 22px; }
  .mv-btn .mv-label { font-size: 10px; font-weight: 600; color: var(--gray-text); text-align: center; }
  .mv-btn.active { border-color: var(--jave-blue); background: #e8f0ff; }
  .mv-btn.active .mv-label { color: var(--jave-blue); }

  .condicion-list { display: flex; flex-direction: column; gap: 6px; }
  .cond-card {
    border: 1.5px solid var(--gray-border);
    border-radius: 10px;
    padding: 11px 12px;
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    background: var(--white);
    transition: all .15s;
  }
  .cond-card.selected { border-color: var(--jave-blue); background: #e8f0ff; }
  .cond-card .cc-icon { font-size: 22px; flex-shrink: 0; }
  .cond-card .cc-name { font-size: 13px; font-weight: 600; color: var(--jave-blue); }
  .cond-card .cc-sub { font-size: 11px; color: var(--gray-text); margin-top: 1px; }
  .cond-card .cc-check { margin-left: auto; color: var(--jave-blue); font-size: 18px; }

  .route-field {
    border: 1.5px solid var(--gray-border);
    border-radius: 10px;
    padding: 11px 12px;
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--gray-bg);
    margin-bottom: 6px;
  }
  .rf-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .rf-dot.origin { background: var(--jave-blue); }
  .rf-dot.dest { background: var(--orange-acc); }
  .route-field span { font-size: 13px; color: var(--gray-text); flex: 1; }
  .route-field .rf-action { font-size: 14px; color: var(--jave-blue); }

  .config-cta {
    background: var(--white);
    padding: 10px 14px 14px;
    flex-shrink: 0;
  }
  .config-cta button {
    width: 100%;
    background: var(--jave-yellow);
    color: var(--jave-blue);
    border: none;
    border-radius: 10px;
    padding: 13px;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    letter-spacing: .2px;
  }

  /* ══════════════════════════════════
     SCREEN 4 – NAVEGACIÓN
  ══════════════════════════════════ */
  .nav-map-area {
    position: relative;
    height: 280px;
    background: #e8f0e0;
    overflow: hidden;
    flex-shrink: 0;
  }
  .nav-map-area svg { width: 100%; height: 100%; }

  .nav-overlay {
    position: absolute;
    top: 10px; left: 10px; right: 52px;
    background: rgba(255,255,255,0.95);
    border-radius: 10px;
    padding: 8px 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .nav-overlay .no-icon { font-size: 18px; color: var(--jave-blue); }
  .nav-overlay .no-text { font-size: 12px; font-weight: 600; color: var(--jave-blue); }
  .nav-overlay .no-sub { font-size: 10px; color: var(--gray-text); }

  .route-metrics {
    background: var(--jave-blue);
    padding: 10px 14px;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 4px;
    flex-shrink: 0;
  }
  .rm-item { text-align: center; }
  .rm-val { font-size: 18px; font-weight: 700; color: #fff; }
  .rm-label { font-size: 9px; color: rgba(255,255,255,0.65); margin-top: 1px; text-transform: uppercase; letter-spacing: .4px; }
  .rm-badge { display: inline-block; background: var(--jave-yellow); color: var(--jave-blue); font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 10px; margin-top: 2px; }

  .steps-section {
    background: var(--white);
    padding: 12px 14px;
    flex-shrink: 0;
  }
  .steps-title { font-size: 12px; font-weight: 700; color: var(--jave-blue); text-transform: uppercase; letter-spacing: .5px; margin-bottom: 10px; }
  .step-row {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 8px 0;
    border-bottom: 1px solid var(--gray-border);
  }
  .step-row:last-child { border-bottom: none; }
  .step-num {
    width: 24px; height: 24px;
    border-radius: 50%;
    background: var(--jave-blue);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .step-info { flex: 1; }
  .step-info .si-text { font-size: 12px; color: #1a1a2e; line-height: 1.4; font-weight: 500; }
  .step-info .si-dist { font-size: 10px; color: var(--gray-text); margin-top: 2px; }
  .step-tag {
    font-size: 10px;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 10px;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .st-walk { background: var(--gray-bg); color: var(--gray-text); }
  .st-elev { background: #dbeafe; color: #1e40af; }
  .st-ramp { background: var(--green-light); color: var(--green-acc); }

  /* ══════════════════════════════════
     FLOW NAVIGATION (outside device)
  ══════════════════════════════════ */
  .flow-panel {
    width: 240px;
    padding: 24px 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-self: flex-start;
    margin-top: 40px;
  }
  .flow-title {
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    opacity: .5;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .flow-btn {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 10px;
    padding: 12px 14px;
    cursor: pointer;
    transition: all .15s;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .flow-btn:hover { background: rgba(255,255,255,0.12); }
  .flow-btn.active { background: var(--jave-yellow); border-color: var(--jave-yellow); }
  .flow-btn .fb-num {
    width: 24px; height: 24px;
    border-radius: 50%;
    background: rgba(255,255,255,0.15);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .flow-btn.active .fb-num { background: var(--jave-blue); }
  .flow-btn .fb-text .fb-label { font-size: 13px; font-weight: 600; color: #fff; }
  .flow-btn.active .fb-text .fb-label { color: var(--jave-blue); }
  .flow-btn .fb-text .fb-sub { font-size: 10px; color: rgba(255,255,255,0.5); margin-top: 1px; }
  .flow-btn.active .fb-text .fb-sub { color: rgba(10,36,114,0.6); }
  .flow-arrow {
    color: rgba(255,255,255,0.2);
    text-align: center;
    font-size: 18px;
  }
  .flow-note {
    margin-top: 8px;
    background: rgba(245,200,0,0.1);
    border: 1px solid rgba(245,200,0,0.25);
    border-radius: 10px;
    padding: 12px 14px;
  }
  .flow-note p { font-size: 11px; color: rgba(255,255,255,0.6); line-height: 1.6; }
  .flow-note strong { color: var(--jave-yellow); }
</style>
</head>
<body>

<!-- ══ DEVICE ══ -->
<div class="device">
  <div class="device-inner">

    <!-- STATUS BAR -->
    <div class="status-bar">
      <span>21:22</span>
      <span>PUJ</span>
      <span>◼◼◼ 74%</span>
    </div>

    <!-- ══ SCREEN 1: CATÁLOGO ══ -->
    <div class="screen active" id="s1">
      <div class="app-header" style="justify-content:center;">
        <h1 style="text-align:left;font-size:20px;">JaveMóvil</h1>
      </div>
      <div class="screen-body">
        <div class="catalog-header">
          <div class="catalog-greeting" style="padding-top:14px;">
            <div class="hello">Bienvenida,</div>
            <div class="name">Mariana Cárdenas Prada</div>
          </div>
          <div class="acc-banner" onclick="goTo('s3')">
            <div class="ab-icon">♿</div>
            <div class="ab-text">
              <div class="ab-label">Ruta accesible</div>
              <div class="ab-sub">Nuevo · Navega sin escaleras</div>
            </div>
            <div class="ab-arrow">›</div>
          </div>
        </div>
        <div class="catalog-grid">
          <div class="catalog-item"><div class="ci-icon">📊</div><div class="ci-label">Mis Notas</div></div>
          <div class="catalog-item"><div class="ci-icon">📻</div><div class="ci-label">Javeriana Estéreo</div></div>
          <div class="catalog-item"><div class="ci-icon">📰</div><div class="ci-label">Noticias y Eventos</div></div>
          <div class="catalog-item"><div class="ci-icon">🚗</div><div class="ci-label">Parqueadero</div></div>
          <div class="catalog-item"><div class="ci-icon">🌐</div><div class="ci-label">Portal Institucional</div></div>
          <div class="catalog-item"><div class="ci-icon">🔗</div><div class="ci-label">Intranet</div></div>
          <div class="catalog-item"><div class="ci-icon">🎭</div><div class="ci-label">Agenda Cultural</div></div>
          <div class="catalog-item"><div class="ci-icon">📋</div><div class="ci-label">Directorio</div></div>
          <div class="catalog-item"><div class="ci-icon">🎟️</div><div class="ci-label">Eventos y Servicios</div></div>
          <div class="catalog-item"><div class="ci-icon">🍽️</div><div class="ci-label">Servicios Alimentación</div></div>
          <div class="catalog-item"><div class="ci-icon">🩺</div><div class="ci-label">CAPS</div></div>
          <div class="catalog-item"><div class="ci-icon">🖨️</div><div class="ci-label">Impresión Int.</div></div>
          <div class="catalog-item"><div class="ci-icon">✝️</div><div class="ci-label">Propósito Superior</div></div>
          <div class="catalog-item"><div class="ci-icon">🔔</div><div class="ci-label">Notificaciones</div></div>
          <div class="catalog-item highlight" onclick="goTo('s2')"><div class="ci-icon">🗺️</div><div class="ci-label" style="color:var(--jave-blue-light);font-weight:700;">Campus</div></div>
          <div class="catalog-item"><div class="ci-icon">🚨</div><div class="ci-label">Emergencia</div></div>
          <div class="catalog-item"><div class="ci-icon">⚙️</div><div class="ci-label">Configuración</div></div>
          <div class="catalog-item"><div class="ci-icon">💳</div><div class="ci-label">Pago Facturas</div></div>
          <div class="catalog-item highlight" onclick="goTo('s3')"><div class="ci-icon">♿</div><div class="ci-label" style="color:var(--jave-blue-light);font-weight:700;">Rutas Accesibles</div></div>
          <div class="catalog-item"></div>
        </div>
      </div>
      <div class="fab" onclick="alert('Menú JaveMóvil')">
        <div class="fab-circle">🔄</div>
      </div>
    </div>

    <!-- ══ SCREEN 2: CAMPUS + CAPA ACCESIBLE ══ -->
    <div class="screen" id="s2">
      <div class="app-header">
        <button class="back-btn" onclick="goTo('s1')">←</button>
        <h1>Campus</h1>
        <button class="search-btn">🔍</button>
      </div>
      <div class="acc-toggle-bar">
        <span class="att-label">♿ Modo accesible</span>
        <div class="toggle-switch" id="campus-toggle" onclick="toggleCampusMode()"></div>
        <span style="font-size:12px;font-weight:600;color:var(--jave-blue);margin-left:4px;" id="toggle-label">Activo</span>
      </div>
      <div class="campus-map-area">
        <svg viewBox="0 0 375 340" xmlns="http://www.w3.org/2000/svg">
          <!-- base grass -->
          <rect width="375" height="340" fill="#d4e8c2"/>
          <!-- paths -->
          <rect x="60" y="0" width="18" height="340" fill="#c8d8b0" opacity=".6"/>
          <rect x="0" y="140" width="375" height="16" fill="#c8d8b0" opacity=".6"/>
          <!-- buildings simplified -->
          <rect x="80" y="20" width="70" height="55" rx="3" fill="#b8c8a0" stroke="#8aaa60" stroke-width="1"/>
          <text x="115" y="44" text-anchor="middle" font-size="8" fill="#2d5a1e" font-weight="600">Ed. Ó. Calvo</text>
          <text x="115" y="55" text-anchor="middle" font-size="7" fill="#2d5a1e">Biblioteca</text>
